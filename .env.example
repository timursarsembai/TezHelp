NODE_ENV=development
PORT=4000

DATABASE_URL=postgres://tezhelp:tezhelp_dev_password@localhost:5432/tezhelp
POSTGRES_USER=tezhelp
POSTGRES_PASSWORD=tezhelp_dev_password
POSTGRES_DB=tezhelp

REDIS_URL=redis://localhost:6379

S3_ENDPOINT=http://localhost:9000
S3_REGION=local
S3_ACCESS_KEY_ID=tezhelp_dev_access_key
S3_SECRET_ACCESS_KEY=tezhelp_dev_secret_key
S3_BUCKET_PRIVATE=tezhelp-private-dev
MINIO_ROOT_USER=tezhelp_dev_access_key
MINIO_ROOT_PASSWORD=tezhelp_dev_secret_key

CORS_ORIGINS=http://localhost:3000,http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

IDENTITY_OTP_ADAPTER=development
IDENTITY_DEVELOPMENT_OTP=123456
IDENTITY_DEV_AUTH_HEADER_ENABLED=true
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_PHONE_RATE_LIMIT_PER_HOUR=5
OTP_IP_RATE_LIMIT_PER_HOUR=30
SESSION_COOKIE_NAME=tezhelp_session
SESSION_COOKIE_SECURE=false
