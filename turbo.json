{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "S3_BUCKET_PRIVATE",
    "IDENTITY_OTP_ADAPTER",
    "IDENTITY_DEVELOPMENT_OTP",
    "IDENTITY_DEV_AUTH_HEADER_ENABLED",
    "OTP_TTL_SECONDS",
    "OTP_RESEND_COOLDOWN_SECONDS",
    "OTP_MAX_ATTEMPTS",
    "OTP_PHONE_RATE_LIMIT_PER_HOUR",
    "OTP_IP_RATE_LIMIT_PER_HOUR",
    "SESSION_COOKIE_NAME",
    "SESSION_COOKIE_SECURE"
  ],
  "ui": "stream",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
